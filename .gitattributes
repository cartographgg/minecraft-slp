# Normalise line endings to LF in the repo and on checkout.
* text=auto eol=lf

# Binary fixtures and assets — disable text diff/merge.
*.nbt  binary
*.png  binary

# Exclude from `git archive` (and therefore from the Packagist dist tarball
# downloaded by `composer require`).
/.github               export-ignore
/.idea                 export-ignore
/build                 export-ignore
/tests                 export-ignore
/.gitattributes        export-ignore
/.gitignore            export-ignore
/.php-cs-fixer.cache   export-ignore
/.php-cs-fixer.dist.php export-ignore
/.phpunit.cache        export-ignore
/infection.json5       export-ignore
/phpstan.neon          export-ignore
/phpunit.xml           export-ignore
/CONTRIBUTING.md       export-ignore
/cartograph-logo.png   export-ignore
